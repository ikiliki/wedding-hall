# Server (Next.js) — copy to server/.env.local
#
# Same Supabase project as the client. The server uses the ANON key only:
# every protected request forwards the user's JWT, so RLS still enforces
# row ownership. Do NOT add SUPABASE_SERVICE_ROLE_KEY here unless you have
# an explicit admin use case.

SUPABASE_URL=
SUPABASE_ANON_KEY=

# Comma-separated list of browser origins allowed to call this server.
# Local Vite dev (http://localhost:5173 / 127.0.0.1) is always allowed.
# In production set this to your client Vercel URL, e.g.
#   CLIENT_ORIGIN=https://wedding-hall-client.vercel.app
CLIENT_ORIGIN=
