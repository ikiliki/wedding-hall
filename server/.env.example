# Server (Next.js) — copy to server/.env.local

SUPABASE_URL=
SUPABASE_ANON_KEY=

# Required for admin endpoints (vendor CRUD, admin_users checks).
# Find it in: Supabase dashboard → Project Settings → API → service_role key.
# Never expose this to the browser or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of browser origins allowed to call this server.
# Local Vite dev (http://localhost:5173 / 127.0.0.1) is always allowed.
# In production set this to your client Vercel URL, e.g.
#   CLIENT_ORIGIN=https://wedding-hall-gamma.vercel.app
CLIENT_ORIGIN=
