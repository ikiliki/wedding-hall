# Client (Vite) — env reference.
#
# Vite picks env files in this order (later overrides earlier):
#   client/.env                (committed, base values — not used here)
#   client/.env.development    (committed) — dev-mode default for `vite dev`
#   client/.env.production     (committed) — prod-mode default for `vite build`
#   client/.env.local          (gitignored) — your local override, any mode
#   client/.env.{mode}.local   (gitignored) — your local mode-specific override
#
# What lives where:
# - Mode files (.env.development / .env.production) hold non-secret defaults
#   that ship with the repo, e.g. VITE_SERVER_URL.
# - Local files hold your real Supabase URL + anon key for development.
#   `npm run env:local` writes the docker dev keys here.
#   `npm run env:cloud --ref <ref>` writes Supabase Cloud keys here.
#
# Browser still talks to Supabase Auth directly for sign-in / sign-up.
# Data writes (profiles, wedding_budgets) go through the Wedding Hall
# server at VITE_SERVER_URL.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional override of the mode-default in client/.env.{development,production}.
# Set this only if you want to point dev at a deployed API or override prod.
# VITE_SERVER_URL=
