# Client (Vite) — copy to client/.env.local
#
# Browser still talks to Supabase Auth directly for sign-in / sign-up,
# so it needs the URL + anon key. Data writes (profiles, wedding_budgets)
# go through the Wedding Hall server at VITE_SERVER_URL.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Base URL of the Wedding Hall API server.
# - local docker / native dev: http://localhost:3001
# - production: your server Vercel URL, e.g. https://wedding-hall-server.vercel.app
VITE_SERVER_URL=http://localhost:3001
